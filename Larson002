.stat-suffix { font-family:'Bebas Neue',sans-serif; font-size:40px; }
.stat-desc { font-size:14px; color:rgba(0,0,0,0.6); margin-top:8px; font-weight:600; }

/* BACK TO TOP */
.back-top {
  position:fixed; bottom:100px; right:28px; z-index:998;
  width:44px; height:44px; border-radius:50%;
  background:var(--surface); border:1px solid var(--border);
  display:flex; align-items:center; justify-content:center;
  cursor:pointer; transition:all 0.3s;
  opacity:0; pointer-events:none;
}
.back-top.show { opacity:1; pointer-events:all; }
.back-top:hover { background:var(--gold); border-color:var(--gold); }
.back-top:hover svg { stroke:var(--bg); }
.back-top svg { stroke:var(--muted); transition:stroke 0.3s; }

/* THANK YOU PAGE */
.thank-you {
  display:none; position:fixed; inset:0; z-index:9000;
  background:rgba(4,4,10,0.95); backdrop-filter:blur(20px);
  align-items:center; justify-content:center;
}
.thank-you.show { display:flex; }
.ty-box {
  background:var(--surface); border:1px solid var(--border);
  border-radius:20px; padding:60px; text-align:center;
  max-width:480px; width:90%;
  animation: fadeSlideUp 0.5s ease;
}
.ty-icon { font-size:60px; margin-bottom:24px; }
.ty-box h2 {
  font-family:'Bebas Neue',sans-serif;
  font-size:40px; color:var(--gold); margin-bottom:12px;
}
.ty-box p { color:var(--muted); font-size:15px; line-height:1.7; margin-bottom:32px; }
.ty-close {
  background:var(--gold); color:var(--bg);
  border:none; padding:14px 36px; border-radius:6px;
  font-family:'Space Grotesk',sans-serif;
  font-size:14px; font-weight:700; cursor:pointer;
  transition:all 0.3s;
}
.ty-close:hover { background:var(--gold2); }

/* SCROLL REVEAL */
.reveal {
  opacity:0; transform:translateY(32px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.reveal.visible { opacity:1; transform:none; }

/* STATS MOBILE */
@media(max-width:900px){
